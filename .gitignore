# dependências (voltam com npm install)
node_modules/

# build gerado
dist/
.vite/

# sistema e editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# logs
npm-debug.log*
yarn-error.log*
*.log

# variáveis de ambiente
# O .env vai para o repositório de propósito: ele só guarda valores públicos,
# como o Client ID do Google, que já viaja dentro do JavaScript entregue ao
# navegador. Qualquer coisa realmente secreta (chave de API, client secret,
# token) vai em .env.local, que fica de fora.
.env.local
.env.*.local
